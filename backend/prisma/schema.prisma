generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  priceHistory PriceHistory[]
  leadActivities LeadActivity[]

  @@index([email])
}

model Customer {
  id        Int            @id @default(autoincrement())
  name      String         @db.VarChar(100)
  phone     String         @unique @db.VarChar(10)
  email     String?        @db.VarChar(255)
  location  String         @db.VarChar(100)
  createdAt DateTime       @default(now())
  quotes    QuoteRequest[]

  @@index([phone])
  @@index([createdAt])
}

model QuoteRequest {
  id               Int               @id @default(autoincrement())
  enquiryNumber    String            @unique @db.VarChar(32)
  customerId       Int
  company          String?           @db.VarChar(120)
  product          String            @db.VarChar(100)
  quantity         Int
  deliveryDate     DateTime?
  message          String?           @db.VarChar(500)
  status           QuoteStatus       @default(NEW)
  source           LeadSource        @default(WEBSITE)
  priority         LeadPriority      @default(MEDIUM)
  assignedTo       String?           @db.VarChar(100)
  nextFollowUpDate DateTime?
  crmNotes         String?           @db.VarChar(1000)
  pdfUrl           String?           @db.VarChar(255)
  finalAmount      Decimal?          @map("final_amount") @db.Decimal(12, 2)
  paymentToken     String?           @unique @map("payment_token") @db.VarChar(64)
  paymentEnabledAt DateTime?         @map("payment_enabled_at")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  notificationLogs NotificationLog[]
  activities       LeadActivity[]
  document         QuoteDocument?
  payments         Payment[]

  @@index([customerId])
  @@index([enquiryNumber])
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([nextFollowUpDate])
  @@index([createdAt])
}

model Payment {
  id                  Int            @id @default(autoincrement())
  quotationId         Int            @map("quotation_id")
  customerName        String         @map("customer_name") @db.VarChar(100)
  customerPhone       String         @map("customer_phone") @db.VarChar(10)
  customerEmail       String?        @map("customer_email") @db.VarChar(255)
  razorpayOrderId     String         @unique @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId   String?        @unique @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature   String?        @map("razorpay_signature") @db.VarChar(255)
  amount              Decimal        @db.Decimal(12, 2)
  currency            String         @default("INR") @db.VarChar(3)
  paymentMethod       String?        @map("payment_method") @db.VarChar(50)
  status              PaymentStatus  @default(PENDING)
  failureReason       String?        @map("failure_reason") @db.VarChar(500)
  receiptUrl          String?        @map("receipt_path") @db.VarChar(255)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  quotation           QuoteRequest   @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  receipt             PaymentReceipt?

  @@index([quotationId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model PaymentReceipt {
  id          Int      @id @default(autoincrement())
  paymentId   Int      @unique @map("payment_id")
  fileName    String   @map("file_name") @db.VarChar(100)
  contentType String   @map("content_type") @db.VarChar(80)
  content     Bytes
  createdAt   DateTime @default(now()) @map("created_at")
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("payment_receipts")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum QuoteStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  QUOTATION_SENT
  NEGOTIATION
  WON
  LOST
  CLOSED
}

enum LeadSource {
  WEBSITE
  PHONE
  WALK_IN
  WHATSAPP
  INDIAMART
  FACEBOOK
  INSTAGRAM
  REFERENCE
  MANUAL
  CSV_IMPORT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model LeadActivity {
  id        Int          @id @default(autoincrement())
  leadId    Int
  type      ActivityType @default(NOTE)
  note      String       @db.VarChar(1000)
  createdBy Int?
  createdAt DateTime     @default(now())
  lead      QuoteRequest @relation(fields: [leadId], references: [id], onDelete: Cascade)
  admin     Admin?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([createdBy])
  @@index([createdAt])
}

enum ActivityType {
  CREATED
  IMPORTED
  NOTE
  STATUS_CHANGE
}

model NotificationLog {
  id             Int                @id @default(autoincrement())
  quoteRequestId Int
  type           NotificationType   @default(EMAIL)
  recipient      String             @db.VarChar(255)
  status         NotificationStatus
  errorMessage   String?            @db.VarChar(1000)
  createdAt      DateTime           @default(now())
  quoteRequest   QuoteRequest       @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  @@index([quoteRequestId])
  @@index([status])
  @@index([createdAt])
}

enum NotificationType {
  EMAIL
  PDF
  GOOGLE_SHEET
  WHATSAPP
}

enum NotificationStatus {
  SUCCESS
  FAILED
}

model QuoteDocument {
  id             Int          @id @default(autoincrement())
  quoteRequestId Int          @unique
  fileName       String       @db.VarChar(80)
  contentType    String       @db.VarChar(80)
  content        Bytes
  createdAt      DateTime     @default(now())
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  @@index([quoteRequestId])
  @@index([createdAt])
}

model Product {
  id            Int                 @id @default(autoincrement())
  name          String              @db.VarChar(100)
  slug          String              @unique @db.VarChar(120)
  description   String              @db.VarChar(1000)
  standardPrice Decimal             @db.Decimal(10, 2)
  bulkPrice     Decimal             @db.Decimal(10, 2)
  bulkQuantity  Int
  unit          String              @db.VarChar(30)
  image         String              @db.VarChar(255)
  availability  ProductAvailability @default(IN_STOCK)
  updatedAt     DateTime            @updatedAt
  priceHistory  PriceHistory[]

  @@index([slug])
  @@index([availability])
  @@index([updatedAt])
}

model PriceHistory {
  id        Int       @id @default(autoincrement())
  productId Int
  oldPrice  Decimal   @db.Decimal(10, 2)
  newPrice  Decimal   @db.Decimal(10, 2)
  priceType PriceType @default(STANDARD)
  updatedBy Int
  updatedAt DateTime  @default(now())
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  admin     Admin     @relation(fields: [updatedBy], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([updatedBy])
  @@index([updatedAt])
}

model BrickType {
  id                  Int                       @id @default(autoincrement())
  name                String                    @unique @db.VarChar(100)
  length              Decimal                   @db.Decimal(10, 3)
  width               Decimal                   @db.Decimal(10, 3)
  height              Decimal                   @db.Decimal(10, 3)
  dimensionUnit       CalculatorMeasurementUnit @map("dimension_unit")
  pricePerPiece       Decimal                   @map("price_per_piece") @db.Decimal(10, 2)
  defaultWastePercent Decimal                   @map("default_waste_percent") @db.Decimal(5, 2)
  isActive            Boolean                   @default(true) @map("is_active")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([name])
  @@map("brick_types")
}

model WallThickness {
  id             Int                       @id @default(autoincrement())
  displayName    String                    @unique @map("display_name") @db.VarChar(50)
  thicknessValue Decimal                   @map("thickness_value") @db.Decimal(10, 3)
  unit           CalculatorMeasurementUnit
  isActive       Boolean                   @default(true) @map("is_active")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("wall_thickness")
}

enum CalculatorMeasurementUnit {
  MM
  CM
  INCH
}

enum ProductAvailability {
  IN_STOCK
  OUT_OF_STOCK
}

enum PriceType {
  STANDARD
  BULK
}
